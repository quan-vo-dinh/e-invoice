{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-4g7h-8i9j-k0l1m2n3o4p5",
    "name": "Keycloak - NestJS Microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Keycloak",
      "item": [
        {
          "name": "Exchange AuthorizationCode",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/auth?response_type=code&client_id={{clientId}}&scope=openid&redirect_uri=http://localhost:3000/callback",
              "host": ["{{keycloakUrl}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "auth"],
              "query": [
                { "key": "response_type", "value": "code" },
                { "key": "client_id", "value": "{{clientId}}" },
                { "key": "scope", "value": "openid" },
                { "key": "redirect_uri", "value": "http://localhost:3000/callback" }
              ]
            },
            "description": "Dùng để lấy Authorization Code qua trình duyệt hoặc giả lập."
          }
        },
        {
          "name": "Exchange token (standard flow)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "authorization_code" },
                { "key": "client_id", "value": "{{clientId}}" },
                { "key": "client_secret", "value": "{{clientSecret}}", "description": "Nếu client là confidential" },
                { "key": "code", "value": "DÁN_CODE_LẤY_TỪ_BƯỚC_TRÊN_VÀO_ĐÂY" },
                { "key": "redirect_uri", "value": "http://localhost:3000/callback" }
              ]
            },
            "url": {
              "raw": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": ["{{keycloakUrl}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
            }
          }
        },
        {
          "name": "Exchange token (direct access grant)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password" },
                { "key": "client_id", "value": "{{clientId}}" },
                { "key": "username", "value": "quan" },
                { "key": "password", "value": "123123" },
                { "key": "scope", "value": "openid" }
              ]
            },
            "url": {
              "raw": "{{keycloakUrl}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": ["{{keycloakUrl}}"],
              "path": ["realms", "{{realm}}", "protocol", "openid-connect", "token"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "keycloakUrl", "value": "http://localhost:8180" },
    { "key": "realm", "value": "einvoice-app" },
    { "key": "clientId", "value": "einvoice-app" },
    { "key": "clientSecret", "value": "DÁN_SECRET_TRONG_TAB_CREDENTIALS_VÀO_ĐÂY" }
  ]
}
